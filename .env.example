# Copy to .env (local) or set these in the Docker environment.

# Admin login password (required in production).
ADMIN_PASSWORD=changeme

# Secret used to sign the admin session cookie (required in production).
# Generate one with: openssl rand -hex 32
SESSION_SECRET=dev-insecure-session-secret-change-me

# Where the SQLite db + uploaded images live. In Docker this is the mounted
# volume (/data). Locally it defaults to ./data if unset.
# DATA_DIR=/data

# Optional: the public voting URL shown on the admin QR code + copy link.
# Read at runtime, so it works in a pre-built Docker image. If unset, the admin
# page uses its own browser origin. Set this when the admin is reached on a
# different host than voters (e.g. behind a reverse proxy).
# VOTE_URL=https://vote.saltychart.net
